{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "ai-zippy/whatsapp-banner",
	"version": "1.0.0",
	"title": "WhatsApp Banner",
	"category": "ai-zippy",
	"icon": "whatsapp",
	"description": "WhatsApp chat CTA banner",
	"attributes": {
		"title": {
			"type": "string",
			"default": "Prefer to Chat?"
