{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "ai-zippy/store-location",
	"version": "1.0.0",
	"title": "Store Location",
	"category": "ai-zippy",
	"icon": "location",
	"description": "Store location info with map and details.",
	"supports": {
		"html": false,
		"align": ["wide", "full"],
		"spacing": { "margin": true, "padding": true }
	},
	"attributes": {
		"mapImage": { "type": "string", "default": "" },
		"mapEmbed": { "type": "string", "default": "" },
		"label": { "type": "string", "default": "" },
		"title": { "type": "string", "default": "Find Us At <em>Serangoon Central</em>" },
		"address": { "type": "string", "default": "Blk 264 Serangoon Central, #01-231, S550264" },
		"hours": { "type": "string", "default": "Mon – Sun: 9am to 5pm" },
		"addressIconUrl": { "type": "string", "default": "" },
		"hoursIconUrl": { "type": "string", "default": "" },
		"dirText": { "type": "string", "default": "Get Directions" },
		"dirUrl": { "type": "string", "default": "https://maps.google.com" },
		"sectionBackgroundColor": { "type": "string", "default": "#FAF5F0" }
	},
	"textdomain": "ai-zippy",
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css",
	"render": "file:./render.php"
}
