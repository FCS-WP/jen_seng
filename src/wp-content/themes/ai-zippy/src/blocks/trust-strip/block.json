{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "ai-zippy/trust-strip",
	"version": "1.0.0",
	"title": "Trust Strip",
	"category": "ai-zippy",
	"icon": "shield",
	"description": "Horizontal strip with trust items (icon, title, sub).",
	"supports": {
		"html": false,
		"align": ["wide", "full"],
		"spacing": { "margin": true, "padding": true }
	},
	"attributes": {
		"align": {
			"type": "string",
			"default": "full"
		},
		"items": {
			"type": "array",
			"items": {
				"type": "object"
			},
			"default": [
				{ "imgUrl": "", "imgId": 0, "title": "30+ Years Experience", "sub": "Serving Singapore since 1993" },
				{ "imgUrl": "", "imgId": 0, "title": "Personalised Advice", "sub": "One-on-one TCM guidance" },
				{ "imgUrl": "", "imgId": 0, "title": "Wide Product Range", "sub": "Herbs, tonics & premium remedies" },
				{ "imgUrl": "", "imgId": 0, "title": "Family-Owned Business", "sub": "A neighbourhood institution" }
			]
		},
		"backgroundColor": {
			"type": "string",
			"default": "#f5f0e8"
		}
	},
	"textdomain": "ai-zippy",
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css",
	"render": "file:./render.php"
}
