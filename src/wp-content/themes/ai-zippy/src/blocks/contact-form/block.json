{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "ai-zippy/contact-form",
	"version": "1.0.0",
	"title": "Contact Form",
	"category": "ai-zippy",
	"icon": "email",
	"description": "Styled contact enquiry form",
	"supports": {
		"html": true,
		"align": ["wide", "full"]
	},
	"attributes": {
		"title": {
			"type": "string",
			"default": "Send Us an Enquiry"
		},
		"subtitle": {
			"type": "string",
			"default": "Fill in the form below and we'll get back to you as soon as possible — usually within 1 business day."
		},
		"formShortcode": {
			"type": "string",
			"default": ""
		}
	},
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css",
	"render": "file:./render.php"
}
