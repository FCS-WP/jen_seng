{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"color": {
			"palette": [
				{
					"slug": "primary",
					"color": "#8B1A1A",
					"name": "Jen Seng Red"
				},
				{
					"slug": "primary-dark",
					"color": "#6A1010",
					"name": "Red Dark"
				},
				{
					"slug": "primary-light",
					"color": "#F5EAEA",
					"name": "Red Light"
				},
				{
					"slug": "secondary",
					"color": "#e0e0e0",
					"name": "Jen Seng Gray"
				},
				{
					"slug": "secondary-light",
					"color": "#e0e0e0",
					"name": "Gray Light"
				},
				{
					"slug": "background",
					"color": "#FFFDF8",
					"name": "Jen Seng Cream"
				},
				{
					"slug": "cream-dark",
					"color": "#F5F0E8",
					"name": "Cream Dark"
				},
				{
					"slug": "cream-muted",
					"color": "#EDE6D6",
					"name": "Cream Muted"
				},
				{
					"slug": "body-text",
					"color": "#2E2420",
					"name": "Jen Seng Dark"
				},
				{
					"slug": "mid",
					"color": "#6B5E56",
					"name": "Mid"
				},
				{
					"slug": "muted",
					"color": "#A8998E",
					"name": "Muted"
				},
				{
					"slug": "border",
					"color": "#E2D8CC",
					"name": "Border"
				},
				{
					"slug": "white",
					"color": "#FFFFFF",
					"name": "White"
				},
				{
					"slug": "footer-bg",
					"color": "#8B1A1A",
					"name": "Footer Background"
				}
			]
		},
		"custom": {
			"breakpoint": {
				"sm": "480px",
				"md": "768px",
				"lg": "1024px",
				"xl": "1200px",
				"xxl": "1400px"
			}
		},
		"typography": {
			"fontFamilies": [
				{
					"fontFamily": "-apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, 'Helvetica Neue', sans-serif",
					"slug": "system",
					"name": "System"
				},
				{
					"fontFamily": "'Lora', serif",
					"slug": "heading",
					"name": "Heading (Lora)"
				},
				{
					"fontFamily": "'Source Sans 3', sans-serif",
					"slug": "body",
					"name": "Body (Source Sans 3)"
				},
				{
					"fontFamily": "'Noto Serif SC', serif",
					"slug": "decorative",
					"name": "Decorative (Noto Serif SC)"
				}
			],
			"fontSizes": [
				{
					"slug": "tiny",
					"size": "0.75rem",
					"name": "Tiny"
				},
				{
					"slug": "small",
					"size": "0.875rem",
					"name": "Small"
				},
				{
					"slug": "medium",
					"size": "1rem",
					"name": "Medium"
				},
				{
					"slug": "large",
					"size": "1.5rem",
					"name": "Large"
				},
				{
					"slug": "x-large",
					"size": "2.25rem",
					"name": "Extra Large"
				}
			]
		},
		"layout": {
			"contentSize": "1200px",
			"wideSize": "1400px"
		},
		"spacing": {
			"units": [
				"px",
				"em",
				"rem",
				"%",
				"vw",
				"vh"
			]
		}
	},
	"styles": {
		"color": {
			"background": "var(--wp--preset--color--white)",
			"text": "var(--wp--preset--color--primary)"
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--system)",
			"fontSize": "var(--wp--preset--font-size--medium)",
			"lineHeight": "1.6"
		},
		"spacing": {
			"blockGap": "0"
		},
		"blocks": {
			"ai-zippy/home-hero": {
				"spacing": {
					"margin": {
						"top": "0"
					}
				}
			}
		}
	},
	"templateParts": [
		{
			"name": "header",
			"title": "Header",
			"area": "header"
		},
		{
			"name": "footer",
			"title": "Footer",
			"area": "footer"
		}
	],
	"customTemplates": [
		{
			"name": "blank",
			"title": "Blank",
			"postTypes": [
				"page",
				"post"
			]
		},
		{
			"name": "page-about",
			"title": "About",
			"postTypes": [
				"page"
			]
		},
		{
			"name": "page-contact",
			"title": "Contact",
			"postTypes": [
				"page"
			]
		},
		{
			"name": "page-cart",
			"title": "Cart",
			"postTypes": [
				"page"
			]
		},
		{
			"name": "page-checkout",
			"title": "Checkout",
			"postTypes": [
				"page"
			]
		}
	]
}